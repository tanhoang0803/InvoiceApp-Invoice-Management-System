@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Dashboard</h2>
    <a asp-page="/Invoices/Create" class="btn btn-primary">+ New Invoice</a>
</div>

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card text-bg-primary h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="small text-white-50">Total Invoices</div>
                        <div class="fs-2 fw-bold">@Model.TotalInvoices</div>
                    </div>
                    <span class="fs-3">🧾</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card text-bg-success h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="small text-white-50">Paid</div>
                        <div class="fs-2 fw-bold">@Model.PaidCount</div>
                        <div class="small text-white-50">@Model.TotalRevenue.ToString("C")</div>
                    </div>
                    <span class="fs-3">✅</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card text-bg-warning h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="small" style="opacity:.75">Pending</div>
                        <div class="fs-2 fw-bold">@Model.PendingCount</div>
                        <div class="small" style="opacity:.75">@Model.PendingRevenue.ToString("C")</div>
                    </div>
                    <span class="fs-3">⏳</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card text-bg-dark h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="small text-white-50">Total Revenue</div>
                        <div class="fs-2 fw-bold">@((Model.TotalRevenue + Model.PendingRevenue).ToString("C"))</div>
                    </div>
                    <span class="fs-3">💰</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Invoices -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Recent Invoices</strong>
        <a asp-page="/Invoices/Index" class="btn btn-sm btn-outline-secondary">View All</a>
    </div>
    <div class="card-body p-0">
        @if (!Model.RecentInvoices.Any())
        {
            <div class="text-center py-5 text-muted">
                <div class="fs-1 mb-2">📄</div>
                <p class="mb-3">No invoices yet. Create your first one!</p>
                <a asp-page="/Invoices/Create" class="btn btn-primary">+ New Invoice</a>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Invoice No</th>
                        <th>Client</th>
                        <th>Status</th>
                        <th class="text-end">Amount</th>
                        <th>Due Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inv in Model.RecentInvoices)
                    {
                        <tr style="cursor:pointer" onclick="location.href='@Url.Page("/Invoices/Details", new { id = inv.Id })'">
                            <td>@inv.InvoiceNo</td>
                            <td>@inv.Client.Name</td>
                            <td>
                                @if (inv.PaymentStatus == invoice_database.Models.PaymentStatus.Paid)
                                {
                                    <span class="badge bg-success">Paid</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }
                            </td>
                            <td class="text-end">@inv.TotalAmount.ToString("C")</td>
                            <td>@inv.DueDate.ToString("yyyy-MM-dd")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
