@page "{id:int}"
@model invoice_database.Pages.Invoices.DetailsModel
@{
    ViewData["Title"] = $"Invoice {Model.Invoice.InvoiceNo}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Invoice #@Model.Invoice.InvoiceNo</h2>
    <div>
        <a asp-page="Edit" asp-route-id="@Model.Invoice.Id" class="btn btn-outline-primary">Edit</a>
        <a asp-page="Index" class="btn btn-secondary ms-2">Back to List</a>
    </div>
</div>
<hr />

<div class="row mb-4">
    <div class="col-md-6">
        <h5>Invoice Details</h5>
        <dl class="row">
            <dt class="col-sm-5">Invoice No</dt>
            <dd class="col-sm-7">@Model.Invoice.InvoiceNo</dd>

            <dt class="col-sm-5">Status</dt>
            <dd class="col-sm-7">
                @if (Model.Invoice.PaymentStatus == invoice_database.Models.PaymentStatus.Paid)
                {
                    <span class="badge bg-success">Paid</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Pending</span>
                }
            </dd>

            <dt class="col-sm-5">Issue Date</dt>
            <dd class="col-sm-7">@Model.Invoice.IssueDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-5">Due Date</dt>
            <dd class="col-sm-7">@Model.Invoice.DueDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-5">Created At</dt>
            <dd class="col-sm-7">@Model.Invoice.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
        </dl>
    </div>

    <div class="col-md-6">
        <h5>Client Information</h5>
        <dl class="row">
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.Invoice.Client.Name</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@(Model.Invoice.Client.Email ?? "—")</dd>

            <dt class="col-sm-4">Phone</dt>
            <dd class="col-sm-8">@(Model.Invoice.Client.Phone ?? "—")</dd>

            <dt class="col-sm-4">Address</dt>
            <dd class="col-sm-8">@(Model.Invoice.Client.Address ?? "—")</dd>
        </dl>
    </div>
</div>

<h5>Services</h5>
<table class="table table-bordered">
    <thead class="table-light">
        <tr>
            <th>Service Name</th>
            <th class="text-end" style="width:100px;">Qty</th>
            <th class="text-end" style="width:140px;">Unit Price</th>
            <th class="text-end" style="width:140px;">Total</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model.Invoice.Services)
        {
            <tr>
                <td>@s.ServiceName</td>
                <td class="text-end">@s.Quantity</td>
                <td class="text-end">@s.UnitPrice.ToString("C")</td>
                <td class="text-end">@s.TotalPrice.ToString("C")</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr class="fw-bold table-light">
            <td colspan="3" class="text-end">Grand Total</td>
            <td class="text-end">@Model.Invoice.TotalAmount.ToString("C")</td>
        </tr>
    </tfoot>
</table>
